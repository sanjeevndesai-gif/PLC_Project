<Window x:Class="CopaLicenseGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Copa License Generator"
        Height="560" Width="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Copa License Generator" FontSize="22" FontWeight="Bold"/>
            <TextBlock Text="Generate signed machine-locked license.json for CopaFormGui"
                       FontSize="12"
                       Foreground="#666"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Product" Margin="0,8,8,8" VerticalAlignment="Center"/>
            <TextBox x:Name="ProductTextBox" Grid.Row="0" Grid.Column="1" Margin="0,6,8,6" Text="CopaFormGui"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Customer Name" Margin="0,8,8,8" VerticalAlignment="Center"/>
            <TextBox x:Name="CustomerTextBox" Grid.Row="1" Grid.Column="1" Margin="0,6,8,6"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Machine ID" Margin="0,8,8,8" VerticalAlignment="Center"/>
            <TextBox x:Name="MachineIdTextBox" Grid.Row="2" Grid.Column="1" Margin="0,6,8,6"/>
            <Button Grid.Row="2" Grid.Column="2" Content="Use This PC" Padding="10,4" Margin="0,6,0,6" Click="UseThisMachineId_Click"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Private Key PEM" Margin="0,8,8,8" VerticalAlignment="Center"/>
            <TextBox x:Name="PrivateKeyPathTextBox" Grid.Row="3" Grid.Column="1" Margin="0,6,8,6"/>
            <Button Grid.Row="3" Grid.Column="2" Content="Browse..." Padding="10,4" Margin="0,6,0,6" Click="BrowsePrivateKey_Click"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Output Path" Margin="0,8,8,8" VerticalAlignment="Center"/>
            <TextBox x:Name="OutputPathTextBox" Grid.Row="4" Grid.Column="1" Margin="0,6,8,6" Text="license.json"/>
            <Button Grid.Row="4" Grid.Column="2" Content="Browse..." Padding="10,4" Margin="0,6,0,6" Click="BrowseOutput_Click"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Expires UTC (optional)" Margin="0,8,8,8" VerticalAlignment="Center"/>
            <TextBox x:Name="ExpiresUtcTextBox" Grid.Row="5" Grid.Column="1" Margin="0,6,8,6"/>
            <TextBlock Grid.Row="6" Grid.Column="1" Text="ISO format example: 2027-12-31T23:59:59Z"
                       Foreground="#666" FontSize="11" Margin="0,0,8,8"/>

            <Border Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,8,0,0" BorderThickness="1" BorderBrush="#DDD" CornerRadius="4" Padding="10">
                <TextBox x:Name="StatusTextBox"
                         BorderThickness="0"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="Transparent"
                         MinHeight="110"/>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Generate License" Padding="14,8" Margin="0,0,8,0" Click="Generate_Click"/>
            <Button Content="Close" Padding="14,8" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
