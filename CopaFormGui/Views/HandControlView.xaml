<UserControl x:Class="CopaFormGui.Views.HandControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="6" Padding="16,10" Margin="0,0,0,8">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Hand Control – Manual Jog" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Use jog buttons to move each axis manually" FontSize="12" Foreground="#BBDEFB" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse Width="16" Height="16" Margin="0,0,6,0"
                             Fill="{Binding IsConnected, Converter={StaticResource BoolToConnectionColor}}"/>
                    <TextBlock Text="{Binding IsConnected, Converter={StaticResource BoolToStatusText}}"
                               Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Step Size + Feed Override + Home buttons -->
            <StackPanel Grid.Column="0" Margin="0,0,8,0">

                <!-- Step Size Selection -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Jog Step Size (mm)" Style="{StaticResource SectionHeaderStyle}"/>
                        <RadioButton Content="0.01 mm" GroupName="JogStep" Margin="0,4,0,0" FontSize="13"
                                     IsChecked="{Binding JogStep, Converter={StaticResource EqualityToBool}, ConverterParameter=0.01, Mode=TwoWay}"/>
                        <RadioButton Content="0.10 mm" GroupName="JogStep" Margin="0,4,0,0" FontSize="13"
                                     IsChecked="{Binding JogStep, Converter={StaticResource EqualityToBool}, ConverterParameter=0.1, Mode=TwoWay}"/>
                        <RadioButton Content="1.00 mm" GroupName="JogStep" Margin="0,4,0,0" FontSize="13"
                                     IsChecked="{Binding JogStep, Converter={StaticResource EqualityToBool}, ConverterParameter=1, Mode=TwoWay}"/>
                        <RadioButton Content="10.0 mm" GroupName="JogStep" Margin="0,4,0,0" FontSize="13"
                                     IsChecked="{Binding JogStep, Converter={StaticResource EqualityToBool}, ConverterParameter=10, Mode=TwoWay}"/>
                        <RadioButton Content="100  mm" GroupName="JogStep" Margin="0,4,0,0" FontSize="13"
                                     IsChecked="{Binding JogStep, Converter={StaticResource EqualityToBool}, ConverterParameter=100, Mode=TwoWay}"/>
                    </StackPanel>
                </Border>

                <!-- Feed Rate Override -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Feed Override" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" Minimum="1" Maximum="100"
                                    Value="{Binding FeedOverride}"
                                    TickFrequency="10" IsSnapToTickEnabled="False"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding FeedOverride, StringFormat={}{0}%}"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Home / Zero buttons -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Reference" Style="{StaticResource SectionHeaderStyle}"/>
                        <Button Content="Home All Axes"  Command="{Binding HomeAllCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"  Height="34" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Home X" Command="{Binding HomeXCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" Height="30" Margin="0,0,4,0"/>
                            <Button Grid.Column="1" Content="Home Y" Command="{Binding HomeYCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" Height="30" Margin="0,0,4,0"/>
                            <Button Grid.Column="2" Content="Home Z" Command="{Binding HomeZCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" Height="30"/>
                        </Grid>
                        <Button Content="Set Work Zero (W0)" Command="{Binding ZeroAllCommand}"
                                Style="{StaticResource WarningButtonStyle}" Height="32" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- E-Stop -->
                <Button Content="⚠ E-STOP" Command="{Binding EmergencyStopCommand}"
                        Background="Red" Foreground="White" Height="50"
                        FontWeight="Bold" FontSize="16"
                        Style="{StaticResource BaseButtonStyle}" Margin="0,0,0,6"/>
                <Button Content="Reset E-Stop" Command="{Binding ResetEStopCommand}"
                        Style="{StaticResource WarningButtonStyle}" Height="34"
                        Visibility="{Binding IsEmergencyStop, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>

            <!-- Right: Axis Position Displays + Jog Buttons -->
            <StackPanel Grid.Column="1">

                <!-- Axis Positions -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- X -->
                        <Border Grid.Column="0" Background="#E3F2FD" CornerRadius="6" Padding="16,12" Margin="0,0,8,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="X Axis" Style="{StaticResource FormLabelStyle}" HorizontalAlignment="Center" FontSize="14"/>
                                <TextBlock Text="{Binding PosX, StringFormat={}{0:F3}}"
                                           FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="mm" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Y -->
                        <Border Grid.Column="1" Background="#E8F5E9" CornerRadius="6" Padding="16,12" Margin="0,0,8,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="Y Axis" Style="{StaticResource FormLabelStyle}" HorizontalAlignment="Center" FontSize="14"/>
                                <TextBlock Text="{Binding PosY, StringFormat={}{0:F3}}"
                                           FontSize="28" FontWeight="Bold" Foreground="#2E7D32"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="mm" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Z -->
                        <Border Grid.Column="2" Background="#FFF3E0" CornerRadius="6" Padding="16,12">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="Z Axis" Style="{StaticResource FormLabelStyle}" HorizontalAlignment="Center" FontSize="14"/>
                                <TextBlock Text="{Binding PosZ, StringFormat={}{0:F3}}"
                                           FontSize="28" FontWeight="Bold" Foreground="#E65100"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="mm" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Jog Buttons -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Axis Jog Controls" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- X Jog -->
                            <Border Grid.Column="0" Background="#F5F5F5" CornerRadius="6" Padding="12" Margin="0,0,8,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="X Axis" FontSize="14" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                    <Button Content="X +" Command="{Binding JogXPlusCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Height="48" Width="100" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Button Content="X −" Command="{Binding JogXMinusCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Height="48" Width="100" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <!-- Y Jog -->
                            <Border Grid.Column="1" Background="#F5F5F5" CornerRadius="6" Padding="12" Margin="0,0,8,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Y Axis" FontSize="14" FontWeight="Bold" Foreground="#2E7D32"
                                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                    <Button Content="Y +" Command="{Binding JogYPlusCommand}"
                                            Background="#2E7D32" Foreground="White"
                                            Style="{StaticResource BaseButtonStyle}"
                                            Height="48" Width="100" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Button Content="Y −" Command="{Binding JogYMinusCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Height="48" Width="100" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <!-- Z Jog -->
                            <Border Grid.Column="2" Background="#F5F5F5" CornerRadius="6" Padding="12">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Z Axis" FontSize="14" FontWeight="Bold" Foreground="#E65100"
                                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                    <Button Content="Z +" Command="{Binding JogZPlusCommand}"
                                            Background="#E65100" Foreground="White"
                                            Style="{StaticResource BaseButtonStyle}"
                                            Height="48" Width="100" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Button Content="Z −" Command="{Binding JogZMinusCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Height="48" Width="100" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="8,6" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
