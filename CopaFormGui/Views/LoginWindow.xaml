<Window x:Class="CopaFormGui.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CopaFormGui.ViewModels"
        mc:Ignorable="d"
        Title="Copa Form – Connect to Controller"
        Height="480" Width="440"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Banner -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Copa Form"
                           FontSize="28" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="CNC Punching Machine Controller"
                           FontSize="12" Foreground="#BBDEFB"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Form Content -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="24,16,24,8">
            <StackPanel>
                <TextBlock Text="Controller Connection"
                           Style="{StaticResource SectionHeaderStyle}"
                           Margin="0,0,0,16"/>

                <!-- IP Address -->
                <TextBlock Text="IP Address" Style="{StaticResource FormLabelStyle}"/>
                <TextBox Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputTextBoxStyle}"
                         Margin="0,0,0,12"/>

                <!-- User Name -->
                <TextBlock Text="User Name" Style="{StaticResource FormLabelStyle}"/>
                <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputTextBoxStyle}"
                         Margin="0,0,0,12"/>

                <!-- Password -->
                <TextBlock Text="Password" Style="{StaticResource FormLabelStyle}"/>
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource InputPasswordBoxStyle}"
                             Margin="0,0,0,12"/>

                <!-- Status / Error Message -->
                <Border Background="#FFF3CD" CornerRadius="4" Padding="10,8"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#856404" FontSize="12" TextWrapping="Wrap"/>
                </Border>

                <!-- Connecting progress -->
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                            Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="Connecting to controller..." FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Margin="24,0,24,24">
            <Button Content="Connect"
                    Command="{Binding ConnectCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Height="40" Margin="0,0,0,8"
                    IsDefault="True"/>
            <Button Content="No Device (Open Offline)"
                    Command="{Binding NoDeviceCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Height="36"/>
        </StackPanel>
    </Grid>
</Window>
