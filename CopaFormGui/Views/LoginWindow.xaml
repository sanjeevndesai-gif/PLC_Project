<Window x:Class="CopaFormGui.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CopaFormGui.ViewModels"
        mc:Ignorable="d"
        Title="Copa Form – Connect to Controller"
        Height="560" Width="440"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Banner -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="74" Height="74" CornerRadius="18" Background="#0D3C6B" Padding="10" Margin="0,0,0,10">
                    <Image Source="{StaticResource CopaLogoImage}" Stretch="Uniform"/>
                </Border>
                <TextBlock Text="Copa Form"
                           FontSize="28" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="CNC Punching Machine Controller"
                           FontSize="12" Foreground="#BBDEFB"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                <TextBlock Text="CLIENT TEST BUILD"
                           Style="{StaticResource BrandCaptionStyle}"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Form Content -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="24,16,24,8">
            <StackPanel>
                <TextBlock Text="Controller Connection"
                           Style="{StaticResource SectionHeaderStyle}"
                           Margin="0,0,0,16"/>

                <!-- IP Address -->
                <TextBlock Text="IP Address" Style="{StaticResource FormLabelStyle}"/>
                <TextBox Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputTextBoxStyle}"
                         Margin="0,0,0,12"/>

                <!-- User Name -->
                <TextBlock Text="User Name" Style="{StaticResource FormLabelStyle}"/>
                <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputTextBoxStyle}"
                         Margin="0,0,0,12"/>

                <!-- Password -->
                <TextBlock Text="Password" Style="{StaticResource FormLabelStyle}"/>
                <PasswordBox x:Name="PasswordBox"
                             PasswordChanged="PasswordBox_PasswordChanged"
                             Style="{StaticResource InputPasswordBoxStyle}"
                             Margin="0,0,0,12"/>

                <!-- Status Message -->
                <Border CornerRadius="4" Padding="10,8" Margin="0,4,0,4"
                        Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibility}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#E3F2FD"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasError}" Value="True">
                                    <Setter Property="Background" Value="#FFEBEE"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{Binding HasError, Converter={StaticResource BoolToErrorBrush}}"
                               FontSize="12" TextWrapping="Wrap" MinHeight="18"/>
                </Border>

                <!-- Connecting progress -->
                <StackPanel Margin="0,8,0,0"
                            Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="Please wait, connecting to controller..."
                               FontSize="12" FontWeight="SemiBold" FontStyle="Italic"
                               Foreground="{StaticResource PrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <ProgressBar IsIndeterminate="True" Height="10"
                                 Foreground="{StaticResource PrimaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Margin="24,0,24,24">
            <Button x:Name="ConnectButton"
                Content="Connect"
                    Click="ConnectButton_Click"
                Background="{StaticResource PrimaryBrush}"
                Foreground="White"
                FontSize="13"
                FontWeight="SemiBold"
                Cursor="Hand"
                    Height="40" Margin="0,0,0,8"
                    IsDefault="True"/>
            <Button Content="No Device (Open Offline)"
                    Command="{Binding NoDeviceCommand}"
                Background="#757575"
                Foreground="White"
                FontSize="13"
                FontWeight="SemiBold"
                Cursor="Hand"
                    Height="36"/>
        </StackPanel>
    </Grid>
</Window>
