<UserControl x:Class="CopaFormGui.Views.IOMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="6" Padding="16,10" Margin="0,0,0,8">
            <Grid>
                <StackPanel>
                    <TextBlock Text="I/O Monitor – Digital Inputs &amp; Outputs" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Real-time PLC digital I/O status" FontSize="12" Foreground="#BBDEFB" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content: Inputs + Outputs side by side -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- INPUTS -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,6,0" Padding="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Digital Inputs" Style="{StaticResource SectionHeaderStyle}"
                               Margin="4,0,0,8" Foreground="{StaticResource PrimaryBrush}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Inputs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,4" Padding="8,6" CornerRadius="4"
                                            Background="{Binding State, Converter={StaticResource IOStateToBrush}, ConverterParameter=input}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="40"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- LED indicator -->
                                            <Ellipse Grid.Column="0" Width="12" Height="12"
                                                     Fill="{Binding State, Converter={StaticResource IOStateToBrush}}"
                                                     Stroke="#BDBDBD" StrokeThickness="1"
                                                     VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Description}"
                                                       FontSize="12" VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding State, Converter={StaticResource BoolToStatusText}}"
                                                       FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"
                                                       Foreground="{Binding State, Converter={StaticResource BoolToConnectionColor}}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- OUTPUTS -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="6,0,0,0" Padding="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Digital Outputs" Style="{StaticResource SectionHeaderStyle}"
                               Margin="4,0,0,8" Foreground="{StaticResource AccentBrush}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Outputs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,4" Padding="8,6" CornerRadius="4"
                                            Background="{Binding State, Converter={StaticResource IOStateToBrush}, ConverterParameter=output}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- LED indicator -->
                                            <Ellipse Grid.Column="0" Width="12" Height="12"
                                                     Fill="{Binding State, Converter={StaticResource IOStateToBrush}}"
                                                     Stroke="#BDBDBD" StrokeThickness="1"
                                                     VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Description, TargetNullValue='(No Description)'}"
                                                       FontSize="12" VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <!-- ToggleButton for the five special outputs -->
                                            <ContentControl Grid.Column="2">
                                                <ContentControl.Style>
                                                    <Style TargetType="ContentControl">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Name}" Value="HYDRAULIC_DOWN_CMD_UI">
                                                                <Setter Property="Content">
                                                                    <Setter.Value>
                                                                        <ToggleButton
                                                                            Command="{Binding DataContext.ToggleOutputCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding}"
                                                                            
                                                                            Content="{Binding State, Converter={StaticResource BoolToStatusText}}"
                                                                            Style="{StaticResource PrimaryToggleButtonStyle}"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Name}" Value="CONVEYOR_CMD_UI">
                                                                <Setter Property="Content">
                                                                    <Setter.Value>
                                                                        <ToggleButton
                                                                            IsChecked="{Binding State, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                            Content="{Binding State, Converter={StaticResource BoolToStatusText}}"
                                                                            Style="{StaticResource PrimaryToggleButtonStyle}"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Name}" Value="BUSBAR_CLAMP_C1_UI">
                                                                <Setter Property="Content">
                                                                    <Setter.Value>
                                                                        <ToggleButton
                                                                            IsChecked="{Binding State, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                            Content="{Binding State, Converter={StaticResource BoolToStatusText}}"
                                                                            Style="{StaticResource PrimaryToggleButtonStyle}"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Name}" Value="BUSBAR_CLAMP_C2_UI">
                                                                <Setter Property="Content">
                                                                    <Setter.Value>
                                                                        <ToggleButton
                                                                            IsChecked="{Binding State, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                            Content="{Binding State, Converter={StaticResource BoolToStatusText}}"
                                                                            Style="{StaticResource PrimaryToggleButtonStyle}"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Name}" Value="BUSBAR_HOLD_CYL_UI">
                                                                <Setter Property="Content">
                                                                    <Setter.Value>
                                                                        <ToggleButton
                                                                            IsChecked="{Binding State, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                            Content="{Binding State, Converter={StaticResource BoolToStatusText}}"
                                                                            Style="{StaticResource PrimaryToggleButtonStyle}"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <!-- Default: status text only for all other outputs -->
                                                            <DataTrigger Binding="{Binding Name}" Value="">
                                                                <Setter Property="Content">
                                                                    <Setter.Value>
                                                                        <TextBlock Text="{Binding State, Converter={StaticResource BoolToStatusText}}"
                                                                                   FontSize="11" FontWeight="SemiBold"
                                                                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                                                                   Foreground="{Binding State, Converter={StaticResource BoolToConnectionColor}, FallbackValue=Gray, TargetNullValue=Gray}"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ContentControl.Style>
                                            </ContentControl>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="8,6" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal">
                <Button Content="Refresh" Command="{Binding RefreshCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,12,0"/>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
