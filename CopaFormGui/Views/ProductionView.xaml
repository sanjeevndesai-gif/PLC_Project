<UserControl x:Class="CopaFormGui.Views.ProductionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="6" Padding="16,10" Margin="0,0,0,8">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Production Counter" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Shift tracking – parts completed, rejected, efficiency" FontSize="12" Foreground="#BBDEFB" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse Width="16" Height="16" Margin="0,0,6,0"
                             Fill="{Binding IsConnected, Converter={StaticResource BoolToConnectionColor}}"/>
                    <TextBlock Text="{Binding IsConnected, Converter={StaticResource BoolToStatusText}}"
                               Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Current Shift Summary -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Completed -->
            <Border Grid.Column="0" Background="#E8F5E9" CornerRadius="8" Padding="16,12" Margin="0,0,6,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Completed" Style="{StaticResource FormLabelStyle}" HorizontalAlignment="Center" FontSize="12"/>
                    <TextBlock Text="{Binding CompletedCount}" FontSize="32" FontWeight="Bold"
                               Foreground="#2E7D32" HorizontalAlignment="Center"/>
                    <TextBlock Text="parts" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Target -->
            <Border Grid.Column="1" Background="#E3F2FD" CornerRadius="8" Padding="16,12" Margin="0,0,6,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Target" Style="{StaticResource FormLabelStyle}" HorizontalAlignment="Center" FontSize="12"/>
                    <TextBlock Text="{Binding TargetCount}" FontSize="32" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="parts" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Remaining -->
            <Border Grid.Column="2" Background="#FFF8E1" CornerRadius="8" Padding="16,12" Margin="0,0,6,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Remaining" Style="{StaticResource FormLabelStyle}" HorizontalAlignment="Center" FontSize="12"/>
                    <TextBlock Text="{Binding Remaining}" FontSize="32" FontWeight="Bold"
                               Foreground="#F57F17" HorizontalAlignment="Center"/>
                    <TextBlock Text="parts" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Rejected -->
            <Border Grid.Column="3" Background="#FFEBEE" CornerRadius="8" Padding="16,12" Margin="0,0,6,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Rejected" Style="{StaticResource FormLabelStyle}" HorizontalAlignment="Center" FontSize="12"/>
                    <TextBlock Text="{Binding RejectedCount}" FontSize="32" FontWeight="Bold"
                               Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="parts" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Efficiency -->
            <Border Grid.Column="4" Background="#F3E5F5" CornerRadius="8" Padding="16,12">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Efficiency" Style="{StaticResource FormLabelStyle}" HorizontalAlignment="Center" FontSize="12"/>
                    <TextBlock Text="{Binding Efficiency, StringFormat={}{0:F1}%}" FontSize="32" FontWeight="Bold"
                               Foreground="#6A1B9A" HorizontalAlignment="Center"/>
                    <TextBlock Text="of target" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Middle: Job Info + Progress + Controls | History -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Job Info + Controls -->
            <StackPanel Grid.Column="0" Margin="0,0,8,0">

                <!-- Current Job -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Current Job" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Job:" Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentJob}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Part:" Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" Margin="0,6,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentPart}" FontSize="12" VerticalAlignment="Center" Margin="0,6,0,0" TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Operator:" Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" Margin="0,6,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CurrentOperator}" FontSize="12" VerticalAlignment="Center" Margin="0,6,0,0"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Shift Start:" Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" Margin="0,6,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ShiftStartDisplay}" FontSize="12" VerticalAlignment="Center" Margin="0,6,0,0"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="Elapsed: " Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ElapsedDisplay}" FontWeight="Bold" FontSize="14"
                                       Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Progress Bar -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Progress" Style="{StaticResource SectionHeaderStyle}"/>
                        <ProgressBar Height="22"
                                     Maximum="100"
                                     Value="{Binding ProgressPct}"
                                     Foreground="{StaticResource SuccessBrush}"
                                     Background="#E0E0E0"
                                     Margin="0,0,0,6"/>
                        <TextBlock HorizontalAlignment="Center" FontSize="12">
                            <Run Text="{Binding CompletedCount}"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding TargetCount}"/>
                            <Run Text="  (" />
                            <Run Text="{Binding ProgressPct, StringFormat={}{0:F1}}"/>
                            <Run Text="%)"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Counter Buttons -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Manual Count" Style="{StaticResource SectionHeaderStyle}"/>
                        <Button Content="✔ Count Good Part" Command="{Binding IncrementGoodCommand}"
                                Style="{StaticResource SuccessButtonStyle}" Height="38" Margin="0,0,0,8"/>
                        <Button Content="✘ Count Reject" Command="{Binding IncrementRejectCommand}"
                                Style="{StaticResource DangerButtonStyle}" Height="38"/>
                    </StackPanel>
                </Border>

                <!-- Shift Controls -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Shift Controls" Style="{StaticResource SectionHeaderStyle}"/>
                        <Button Content="End Shift &amp; Save" Command="{Binding EndShiftCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" Height="36" Margin="0,0,0,6"/>
                        <Button Content="Reset Counters" Command="{Binding ResetShiftCommand}"
                                Style="{StaticResource WarningButtonStyle}" Height="32"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Right: History Table -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Shift History" Style="{StaticResource SectionHeaderStyle}" Margin="4,0,0,8"/>
                    <DataGrid ItemsSource="{Binding History}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Job"        Binding="{Binding JobName}"    Width="90"/>
                            <DataGridTextColumn Header="Part"       Binding="{Binding PartName}"   Width="*"/>
                            <DataGridTextColumn Header="Target"     Binding="{Binding Target}"     Width="60"/>
                            <DataGridTextColumn Header="Completed"  Binding="{Binding Completed}"  Width="80"/>
                            <DataGridTextColumn Header="Rejected"   Binding="{Binding Rejected}"   Width="70"/>
                            <DataGridTextColumn Header="Net"        Binding="{Binding Net}"        Width="55"/>
                            <DataGridTextColumn Header="Eff. %"     Binding="{Binding Efficiency}" Width="60"/>
                            <DataGridTextColumn Header="Duration"   Binding="{Binding Duration}"   Width="110"/>
                            <DataGridTextColumn Header="Operator"   Binding="{Binding Operator}"   Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Footer Status -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="8,6" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
