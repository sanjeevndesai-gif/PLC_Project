<UserControl x:Class="CopaFormGui.Views.PunchingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="6" Padding="16,10" Margin="0,0,0,8">
            <Grid>
                <TextBlock Text="Punching Operations" FontSize="18" FontWeight="Bold" Foreground="White"/>
                <!-- Controller Status -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse Width="16" Height="16" Margin="0,0,6,0"
                             Fill="{Binding IsConnected, Converter={StaticResource BoolToConnectionColor}}"/>
                    <TextBlock Text="{Binding IsConnected, Converter={StaticResource BoolToStatusText}}"
                               Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Program Selection + Controls -->
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <!-- Program List -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Programs" Style="{StaticResource SectionHeaderStyle}"/>
                        <ListBox ItemsSource="{Binding Programs}"
                                 SelectedItem="{Binding SelectedProgram}"
                                 Height="180" BorderThickness="1"
                                 BorderBrush="{StaticResource BorderBrush}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4,2">
                                        <TextBlock Text="{Binding ProgramName}" FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Text="{Binding Description}" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- Machine Mode -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Machine Mode" Style="{StaticResource SectionHeaderStyle}"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Manual" Command="{Binding SetModeManualCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0" Width="80"/>
                            <Button Content="Auto" Command="{Binding SetModeAutoCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,6,0" Width="80"/>
                            <Button Content="Home" Command="{Binding HomeAxesCommand}"
                                    Style="{StaticResource WarningButtonStyle}" Width="80"/>
                        </StackPanel>
                        <TextBlock Margin="0,8,0,0">
                            <Run Text="Mode: " FontWeight="SemiBold"/>
                            <Run Text="{Binding CurrentMode}" Foreground="{StaticResource PrimaryBrush}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Run Controls -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Run Controls" Style="{StaticResource SectionHeaderStyle}"/>
                        <Button Content="&#x25B6; Start Program" Command="{Binding StartProgramCommand}"
                                Style="{StaticResource SuccessButtonStyle}" Height="36" Margin="0,0,0,6"/>
                        <Button Content="&#x25FC; Stop" Command="{Binding StopProgramCommand}"
                                Style="{StaticResource DangerButtonStyle}" Height="36" Margin="0,0,0,6"/>
                        <Button Content="&#x26A0; E-STOP" Command="{Binding EmergencyStopCommand}"
                                Background="Red" Foreground="White" Height="44" FontWeight="Bold" FontSize="14"
                                Style="{StaticResource BaseButtonStyle}"/>
                        <Button Content="Reset E-Stop" Command="{Binding ResetEStopCommand}"
                                Style="{StaticResource WarningButtonStyle}" Height="32" Margin="0,6,0,0"
                                Visibility="{Binding IsEmergencyStop, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Right Panel: Position Display + Status -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Axis Positions -->
                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Current Axis Positions (mm)" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- X -->
                            <Border Grid.Column="0" Background="#E3F2FD" CornerRadius="6" Padding="12" Margin="0,0,8,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="X Axis" Style="{StaticResource FormLabelStyle}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding PosX, StringFormat={}{0:F3}}"
                                               FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- Y -->
                            <Border Grid.Column="1" Background="#E8F5E9" CornerRadius="6" Padding="12" Margin="0,0,8,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Y Axis" Style="{StaticResource FormLabelStyle}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding PosY, StringFormat={}{0:F3}}"
                                               FontSize="22" FontWeight="Bold" Foreground="#2E7D32"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Jog / Move To Target -->
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Move To Target Position" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="X:" Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Grid.Column="1" Text="{Binding TargetX, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBoxStyle}" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="2" Text="Y:" Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Grid.Column="3" Text="{Binding TargetY, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBoxStyle}" Margin="0,0,12,0"/>
                            <Button Grid.Column="4" Content="Move" Command="{Binding MoveToTargetCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" Width="80"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Program Status -->
                <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Program Status" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Program" Style="{StaticResource FormLabelStyle}"/>
                                <TextBlock Text="{Binding ProgramName}" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Completed" Style="{StaticResource FormLabelStyle}"/>
                                <TextBlock Text="{Binding CompletedStrokes}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource SuccessBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Total" Style="{StaticResource FormLabelStyle}"/>
                                <TextBlock Text="{Binding TotalStrokes}" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>
                        <!-- Progress Bar -->
                        <ProgressBar Height="18"
                                     Maximum="{Binding TotalStrokes}"
                                     Value="{Binding CompletedStrokes}"
                                     Foreground="{StaticResource SuccessBrush}"
                                     Background="#E0E0E0"
                                     Margin="0,0,0,12"/>
                        <!-- Status Message -->
                        <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
