<UserControl x:Class="CopaFormGui.Views.OverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="6" Padding="16,10" Margin="0,0,0,8">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Machine Overview" FontSize="18" FontWeight="Bold" Foreground="White"/>
                </StackPanel>

                <!-- Popup for RUN button -->
                <Popup x:Name="RunPopup" Placement="Center" StaysOpen="False">
                    <Border Style="{StaticResource CardStyle}" Width="600" Height="420" Padding="28" Background="White">
                        <StackPanel>
                            <TextBlock Text="Punching parts" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,16"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Length of the bar" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Width="90" Grid.Row="0" Grid.Column="1" Margin="4,0,0,8" Style="{StaticResource InputTextBoxStyle}"
                                         PreviewTextInput="NumericTextBox_PreviewTextInput"
                                         DataObject.Pasting="NumericTextBox_Pasting"/>
                                <TextBlock Text="Number of parts" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Width="90" Grid.Row="1" Grid.Column="1" Margin="4,0,0,8" Style="{StaticResource InputTextBoxStyle}"
                                         PreviewTextInput="NumericTextBox_PreviewTextInput"
                                         DataObject.Pasting="NumericTextBox_Pasting"/>
                                <TextBlock Text="Part off" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource FormLabelStyle}"/>
                                <CheckBox Grid.Row="2" Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                            <Border Background="#F4F7FB" CornerRadius="6" Padding="2" Margin="0,0,0,12">
                                <DataGrid AutoGenerateColumns="False" HeadersVisibility="Column" Height="100" Margin="0" BorderThickness="0" ItemsSource="{Binding RunPopupPunchRows}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ToolId" Binding="{Binding ToolId}" Width="60"/>
                                        <DataGridTextColumn Header="Tool" Binding="{Binding Tool}" Width="60"/>
                                        <DataGridTextColumn Header="Punch" Binding="{Binding Punch}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                <Button Content="✔" Width="44" Height="36" Click="RunPopupOk_Click" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                                <Button Content="✖" Width="44" Height="36" Click="RunPopupCancel_Click" Style="{StaticResource SecondaryButtonStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
        </Border>

        <!-- Main content: Job + Controller info (no Axis) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- Left side: 2D / 3D perspective preview (same pattern as Program Editor) -->
            <TabControl Grid.Column="0" Margin="0,0,6,0"
                        BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">

                <TabItem Header="2D Punch Preview">
                    <Border Background="#53C8F0" BorderBrush="#2A9CCB" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Axis Graphic in top left corner -->
                                <StackPanel Orientation="Vertical" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="8,6,0,0">
                                    <TextBlock Text="Top View Preview" FontSize="12" FontWeight="SemiBold" Foreground="#124A77" HorizontalAlignment="Left"/>
                                    <Canvas Width="100" Height="100" Margin="0,1,0,0" IsHitTestVisible="False">
                                        <!-- X axis (right, length 60) -->
                                        <Line X1="20" Y1="20" X2="80" Y2="20" Stroke="#0D3B66" StrokeThickness="1.6"/>
                                        <Polygon Points="80,16 90,20 80,24" Fill="#0D3B66"/>
                                        <TextBlock Canvas.Left="92" Canvas.Top="12" Text="X" FontSize="11" FontWeight="Bold" Foreground="#0D3B66"/>
                                        <!-- Y axis (down, length 60) -->
                                        <Line X1="20" Y1="20" X2="20" Y2="80" Stroke="#0D3B66" StrokeThickness="1.6"/>
                                        <Polygon Points="16,80 20,90 24,80" Fill="#0D3B66"/>
                                        <TextBlock Canvas.Left="28" Canvas.Top="82" Text="Y" FontSize="11" FontWeight="Bold" Foreground="#0D3B66"/>
                                    </Canvas>
                                </StackPanel>
                            </Grid>

                            <!-- Preview Area -->
                            <ScrollViewer Grid.Row="1"
                                          Margin="8,0,8,8"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          CanContentScroll="False"
                                          PanningMode="Both">
                                <Canvas Width="520" Height="300" HorizontalAlignment="Center" VerticalAlignment="Center"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Canvas.RenderTransform>
                                        <ScaleTransform ScaleX="{Binding PreviewZoom}" ScaleY="{Binding PreviewZoom}"/>
                                    </Canvas.RenderTransform>

                                    <Rectangle Canvas.Left="{Binding PreviewSheetLeft}"
                                               Canvas.Top="{Binding PreviewSheetTop}"
                                               Width="{Binding PreviewSheetWidth}"
                                               Height="{Binding PreviewSheetHeight}"
                                               Fill="#DCEBF7"
                                               Stroke="#577D97"
                                               StrokeThickness="2"
                                               Opacity="0.9"/>

                                    <Rectangle Canvas.Left="{Binding PreviewSheetLeft}"
                                               Canvas.Top="{Binding PreviewSheetTop}"
                                               Width="{Binding PreviewSheetWidth}"
                                               Height="{Binding PreviewSheetHeight}"
                                               Fill="#F2EBE3"
                                               Stroke="#202020"
                                               StrokeThickness="3"/>

                                    <ItemsControl ItemsSource="{Binding ToolPreviewShapes}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding CanvasLeft}"/>
                                                <Setter Property="Canvas.Top" Value="{Binding CanvasTop}"/>
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Ellipse Width="{Binding ShapeWidth}"
                                                             Height="{Binding ShapeHeight}"
                                                             Fill="{Binding FillColor}"
                                                             Stroke="{Binding StrokeColor}"
                                                             StrokeThickness="2"
                                                             Visibility="{Binding IsRound, Converter={StaticResource BoolToVisibility}}"/>
                                                    <Rectangle Width="{Binding ShapeWidth}"
                                                               Height="{Binding ShapeHeight}"
                                                               Fill="{Binding FillColor}"
                                                               Stroke="{Binding StrokeColor}"
                                                               StrokeThickness="2"
                                                               Visibility="{Binding IsSquare, Converter={StaticResource BoolToVisibility}}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Canvas>
                            </ScrollViewer>

                            <!-- L/W/T Info Panel OUTSIDE Canvas -->
                            <Border Grid.Row="2" Width="320" Height="36" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                    Background="#B3FFFFFF" BorderBrush="#7FA8C5" BorderThickness="1" CornerRadius="4" Padding="6,3" Margin="0,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="L:" FontWeight="SemiBold" Foreground="#0D3B66" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding RecentLengthText}" Foreground="#0D3B66" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="W:" FontWeight="SemiBold" Foreground="#0D3B66" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding RecentWidthText}" Foreground="#0D3B66" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="T:" FontWeight="SemiBold" Foreground="#7A1E1E" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="5" Text="{Binding RecentThicknessText}" Foreground="#7A1E1E" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Zoom Controls OUTSIDE Canvas -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,16,8"
                                        Background="#F8F9FAAA">
                                <Button Content="-" Width="28" Height="24" Command="{Binding ZoomOutPreviewCommand}"
                                        Background="#FFFFFF" Foreground="#0D3B66" BorderBrush="#5B9BD5" BorderThickness="1" FontWeight="Bold"/>
                                <TextBlock Width="56" TextAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="#123D5C"
                                           Text="{Binding PreviewZoom, StringFormat={}{0:F1}x}"/>
                                <Button Content="+" Width="28" Height="24" Command="{Binding ZoomInPreviewCommand}"
                                        Background="#FFFFFF" Foreground="#0D3B66" BorderBrush="#5B9BD5" BorderThickness="1" FontWeight="Bold"/>
                                <Button Content="Reset" Width="52" Height="24" Command="{Binding ResetPreviewZoomCommand}"
                                        Background="#FFF3CD" Foreground="#8A6D3B" BorderBrush="#E3C766" BorderThickness="1" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </TabItem>


            </TabControl>

            <!-- Properties panel -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="10">
                <StackPanel>
                    <Button Width="80" Height="32" Margin="0,0,0,12" Click="RunButton_Click" Style="{StaticResource PrimaryButtonStyle}">
                        <Grid Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse Width="24" Height="24" Fill="White" Opacity="0.2"/>
                            <Path Data="M10,7 L20,12 L10,17 Z" Fill="White" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Width="14" Height="14"/>
                        </Grid>
                    </Button>
                    <TextBlock Text="Properties" Style="{StaticResource SectionHeaderStyle}"/>
                    <TextBlock Text="Comment:" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Height="26" Margin="0,2,0,8"
                             Text="{Binding RecentComment}"
                             IsReadOnly="True"/>

                    <TextBlock Text="Material:" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Height="26" Margin="0,2,0,8"
                             Text="{Binding RecentMaterial}"
                             IsReadOnly="True"/>

                    <TextBlock Text="Length x width:" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Height="26" Margin="0,2,0,8"
                             Text="{Binding RecentLengthWidth}"
                             IsReadOnly="True"/>

                    <TextBlock Text="Thickness:" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Height="26" Margin="0,2,0,8"
                             Text="{Binding RecentThickness}"
                             IsReadOnly="True"/>

                    <Button Content="Pause" Height="32" Margin="0,0,0,8"
                            Command="{Binding PauseCommand}"/>

                    <!-- Display last saved file content -->
                    <TextBlock Text="Last Saved File Content:" Style="{StaticResource FormLabelStyle}" Margin="0,8,0,0"/>
                    <ScrollViewer Height="120" VerticalScrollBarVisibility="Auto" Margin="0,2,0,8">
                        <TextBox Text="{Binding LastSavedFileContent}" IsReadOnly="True" TextWrapping="NoWrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" BorderThickness="1"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Footer: Axis Positions in one line -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,8,0,0">
            <!-- X Position -->
            <StackPanel Orientation="Horizontal" Margin="0,0,32,0">
                <TextBlock Text="X:" FontSize="14" FontWeight="Bold" Foreground="#333" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding PosX, StringFormat={}{0:F3}}"
                               FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="mm" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="6,6,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Y Position -->
            <StackPanel Orientation="Horizontal" Margin="0,0,32,0">
                <TextBlock Text="Y:" FontSize="14" FontWeight="Bold" Foreground="#333" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding PosY, StringFormat={}{0:F3}}"
                               FontSize="18" FontWeight="Bold" Foreground="#2E7D32"/>
                    <TextBlock Text="mm" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="6,6,0,0"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
