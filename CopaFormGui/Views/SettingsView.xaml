<UserControl x:Class="CopaFormGui.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="SettingsFieldLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource FormLabelStyle}">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <Style x:Key="SettingsValueBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InputTextBoxStyle}">
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
        </Style>

        <Style x:Key="SettingsTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="SettingsTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="#E7EDF5"
                                BorderBrush="#C5D2E1"
                                BorderThickness="1"
                                CornerRadius="6,6,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="White"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="Margin" Value="12,-12,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="6" Padding="16,10" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Settings" FontSize="18" FontWeight="Bold" Foreground="White"/>
                
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1"
                    SelectedIndex="{Binding SelectedTabIndex}"
                    Style="{StaticResource SettingsTabControlStyle}">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem" BasedOn="{StaticResource SettingsTabItemStyle}"/>
            </TabControl.ItemContainerStyle>
            <TabItem Header="General">
                <Border Style="{StaticResource CardStyle}" Padding="10" Margin="0,8,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0" Padding="18,14,18,14">
                            <Grid>
                                <TextBlock Text="Speed settings" Style="{StaticResource SettingsSectionTitleStyle}"/>
                                <Grid Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Jog Speed" Style="{StaticResource SettingsFieldLabelStyle}"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SpeedX, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsValueBoxStyle}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="mm" Style="{StaticResource FormLabelStyle}" Margin="8,0,0,0" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Home Speed" Style="{StaticResource SettingsFieldLabelStyle}" Margin="0,5,12,0"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SpeedY, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsValueBoxStyle}" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="mm" Style="{StaticResource FormLabelStyle}" Margin="8,5,0,0" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Auto Feedrate" Style="{StaticResource SettingsFieldLabelStyle}" Margin="0,5,12,0"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SpeedXHand, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsValueBoxStyle}" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="mm" Style="{StaticResource FormLabelStyle}" Margin="8,5,0,0" VerticalAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,0" Padding="18,14,18,14">
                            <Grid>
                                <TextBlock Text="Positions and lengths" Style="{StaticResource SettingsSectionTitleStyle}"/>
                                <Grid Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="X minimum" Style="{StaticResource SettingsFieldLabelStyle}"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding XMin, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsValueBoxStyle}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="mm" Style="{StaticResource FormLabelStyle}" Margin="8,0,0,0" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="X maximum" Style="{StaticResource SettingsFieldLabelStyle}" Margin="0,5,12,0"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding XMax, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsValueBoxStyle}" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="mm" Style="{StaticResource FormLabelStyle}" Margin="8,5,0,0" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Y minimum" Style="{StaticResource SettingsFieldLabelStyle}" Margin="0,5,12,0"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding YMin, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsValueBoxStyle}" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="mm" Style="{StaticResource FormLabelStyle}" Margin="8,5,0,0" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Y maximum" Style="{StaticResource SettingsFieldLabelStyle}" Margin="0,5,12,0"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding YMax, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsValueBoxStyle}" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="2" Text="mm" Style="{StaticResource FormLabelStyle}" Margin="8,5,0,0" VerticalAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header="Tool">
                <Border Style="{StaticResource CardStyle}" Padding="10" Margin="0,8,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0" Padding="18,14,18,14">
                            <Grid>
                                <TextBlock Text="General" Style="{StaticResource SettingsSectionTitleStyle}"/>
                                <Grid Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Tool length 1" Style="{StaticResource SettingsFieldLabelStyle}"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ToolLength1, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsValueBoxStyle}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="mm" Style="{StaticResource FormLabelStyle}" Margin="8,0,0,0" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Tool length 2" Style="{StaticResource SettingsFieldLabelStyle}" Margin="0,5,12,0"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ToolLength2, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsValueBoxStyle}" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="mm" Style="{StaticResource FormLabelStyle}" Margin="8,5,0,0" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Tool length 3" Style="{StaticResource SettingsFieldLabelStyle}" Margin="0,5,12,0"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ToolLength3, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsValueBoxStyle}" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="mm" Style="{StaticResource FormLabelStyle}" Margin="8,5,0,0" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Tool length 4" Style="{StaticResource SettingsFieldLabelStyle}" Margin="0,5,12,0"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding ToolLength4, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsValueBoxStyle}" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="2" Text="mm" Style="{StaticResource FormLabelStyle}" Margin="8,5,0,0" VerticalAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,0" Padding="18,14,18,14">
                            <Grid>
                                <TextBlock Text="Offsets" Style="{StaticResource SettingsSectionTitleStyle}"/>
                                <Grid Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Y" Style="{StaticResource FormLabelStyle}" HorizontalAlignment="Center"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Tool 1" Style="{StaticResource SettingsFieldLabelStyle}" Margin="0,5,12,0"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding T1OffsetPos, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsValueBoxStyle}" Width="92" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="mm" Style="{StaticResource FormLabelStyle}" Margin="8,5,0,0" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Tool 2" Style="{StaticResource SettingsFieldLabelStyle}" Margin="0,5,12,0"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding T2OffsetPos, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsValueBoxStyle}" Width="92" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="mm" Style="{StaticResource FormLabelStyle}" Margin="8,5,0,0" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Tool 3" Style="{StaticResource SettingsFieldLabelStyle}" Margin="0,5,12,0"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding T3OffsetPos, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsValueBoxStyle}" Width="92" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="2" Text="mm" Style="{StaticResource FormLabelStyle}" Margin="8,5,0,0" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Tool 4" Style="{StaticResource SettingsFieldLabelStyle}" Margin="0,5,12,0"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding T4OffsetPos, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsValueBoxStyle}" Width="92" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="4" Grid.Column="2" Text="mm" Style="{StaticResource FormLabelStyle}" Margin="8,5,0,0" VerticalAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
                </Border>
            </TabItem>

        </TabControl>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="12,8" Margin="0,8,0,0">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="Settings actions" Style="{StaticResource FormLabelStyle}" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="{StaticResource PrimaryDarkBrush}"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Reset" Command="{Binding ResetDefaultsCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="Apply" Command="{Binding ApplySettingsCommand}" Style="{StaticResource SuccessButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="Save" Command="{Binding SaveSettingsCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
