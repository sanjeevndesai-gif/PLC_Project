<UserControl x:Class="CopaFormGui.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="6" Padding="16,10" Margin="0,0,0,8">
            <Grid>
                <TextBlock Text="Settings" FontSize="18" FontWeight="Bold" Foreground="White"/>
            </Grid>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <!-- Tab 1: Speeds -->
            <TabItem Header="Speed Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                    <StackPanel>
                        <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Speed Settings (mm/min)" Style="{StaticResource SectionHeaderStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <TextBlock Text="Auto Speeds" Style="{StaticResource FormLabelStyle}" Margin="0,0,0,8"/>
                                        <TextBlock Text="Speed X" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox Text="{Binding SpeedX, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,10"/>
                                        <TextBlock Text="Speed Y" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox Text="{Binding SpeedY, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource InputTextBoxStyle}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Hand / Jog Speeds" Style="{StaticResource FormLabelStyle}" Margin="0,0,0,8"/>
                                        <TextBlock Text="X Hand" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox Text="{Binding SpeedXHand, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,10"/>
                                        <TextBlock Text="Y Hand" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox Text="{Binding SpeedYHand, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource InputTextBoxStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 2: Positions & Limits -->
            <TabItem Header="Positions &amp; Limits">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                    <StackPanel>
                        <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Axis Travel Limits (mm)" Style="{StaticResource SectionHeaderStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.ColumnSpan="4" Text="X Axis" Style="{StaticResource FormLabelStyle}" Margin="0,0,0,4"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Min:" Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center"/>
                                    <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding XMin}" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,12,8"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Max:" Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center"/>
                                    <TextBox   Grid.Row="1" Grid.Column="3" Text="{Binding XMax}" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="2" Grid.ColumnSpan="4" Text="Y Axis" Style="{StaticResource FormLabelStyle}" Margin="0,0,0,4"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Min:" Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center"/>
                                    <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding YMin}" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,12,8"/>
                                    <TextBlock Grid.Row="3" Grid.Column="2" Text="Max:" Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center"/>
                                    <TextBox   Grid.Row="3" Grid.Column="3" Text="{Binding YMax}" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,8"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Home Positions (mm)" Style="{StaticResource SectionHeaderStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Home X" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox Text="{Binding HomeX}" Style="{StaticResource InputTextBoxStyle}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Home Y" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox Text="{Binding HomeY}" Style="{StaticResource InputTextBoxStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 3: Tool Lengths -->
            <TabItem Header="Tool">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                    <StackPanel>
                        <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Tool Lengths (mm)" Style="{StaticResource SectionHeaderStyle}"/>
                                <TextBlock Text="Tool Length 1" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Text="{Binding ToolLength1}" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,10" Width="200" HorizontalAlignment="Left"/>
                                <TextBlock Text="Tool Length 2" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Text="{Binding ToolLength2}" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,10" Width="200" HorizontalAlignment="Left"/>
                                <TextBlock Text="Tool Length 3" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Text="{Binding ToolLength3}" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,10" Width="200" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Safety Settings" Style="{StaticResource SectionHeaderStyle}"/>
                                <TextBlock Text="Safety Height (mm)" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Text="{Binding SafetyHeight}" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,10" Width="200" HorizontalAlignment="Left"/>
                                <TextBlock Text="Clamp Force (%)" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Text="{Binding ClampForce}" Style="{StaticResource InputTextBoxStyle}" Width="200" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Bottom Actions -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="8,6" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal">
                <Button Content="Save Settings"    Command="{Binding SaveSettingsCommand}"
                        Style="{StaticResource SuccessButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="Apply to Controller" Command="{Binding ApplySettingsCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="Reset Defaults"   Command="{Binding ResetDefaultsCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,16,0"/>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
