<Window x:Class="CopaFormGui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CopaFormGui.ViewModels"
        xmlns:views="clr-namespace:CopaFormGui.Views"
        mc:Ignorable="d"
        Title="Copa Form – CNC Punching Machine"
        Height="720" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:OverviewViewModel}">
            <views:OverviewView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PunchingViewModel}">
            <views:PunchingView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HandControlViewModel}">
            <views:HandControlView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DatabaseViewModel}">
            <views:DatabaseView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AlarmViewModel}">
            <views:AlarmView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ToolManagementViewModel}">
            <views:ToolManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:IOMonitorViewModel}">
            <views:IOMonitorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProgramEditorViewModel}">
            <views:ProgramEditorView/>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <!-- MENU BAR -->
        <Menu DockPanel.Dock="Top" Background="{StaticResource PrimaryDarkBrush}" Foreground="White" FontSize="13">
            <Menu.ItemContainerStyle>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Padding"    Value="10,6"/>
                </Style>
            </Menu.ItemContainerStyle>
            <MenuItem Header="_File">
                <MenuItem Header="_Exit" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Overview"    Command="{Binding ShowOverviewCommand}"/>
            <MenuItem Header="_Punching"    Command="{Binding ShowPunchingCommand}"/>
            <MenuItem Header="_Hand Control" Command="{Binding ShowHandControlCommand}"/>
            <MenuItem Header="_Database"    Command="{Binding ShowDatabaseCommand}"/>
            <MenuItem Header="T_ools">
                <MenuItem Header="Tool _Management" Command="{Binding ShowToolManagementCommand}"/>
                <MenuItem Header="_Alarms"           Command="{Binding ShowAlarmsCommand}"/>
                <MenuItem Header="_I/O Monitor"      Command="{Binding ShowIOMonitorCommand}"/>
                <MenuItem Header="_Program Editor"   Command="{Binding ShowProgramEditorCommand}"/>
            </MenuItem>
            <MenuItem Header="_Settings" Command="{Binding ShowSettingsCommand}"/>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="AboutMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <!-- TOOLBAR -->
        <ToolBar DockPanel.Dock="Top" Background="{StaticResource ToolbarBrush}" Height="42">
            <Border Background="#31424A" CornerRadius="6" Padding="8,4" Margin="2,0,8,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="{StaticResource CopaLogoImage}" Width="22" Height="22" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="Copa Form" Foreground="White" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="Punch Control" Style="{StaticResource BrandCaptionStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Button Command="{Binding ShowOverviewCommand}" ToolTip="Machine Overview" Margin="2,0"
                    Style="{StaticResource BaseButtonStyle}" Background="Transparent" Foreground="White">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1F4BB;" FontSize="14" Margin="0,0,4,0"/>
                    <TextBlock Text="Overview" FontSize="12"/>
                </StackPanel>
            </Button>
            <Separator/>
            <Button Command="{Binding ShowPunchingCommand}" ToolTip="Punching Operations" Margin="2,0"
                    Style="{StaticResource BaseButtonStyle}" Background="Transparent" Foreground="White">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1F528;" FontSize="14" Margin="0,0,4,0"/>
                    <TextBlock Text="Punching" FontSize="12"/>
                </StackPanel>
            </Button>
            <Separator/>
            <Button Command="{Binding ShowHandControlCommand}" ToolTip="Hand Control" Margin="2,0"
                    Style="{StaticResource BaseButtonStyle}" Background="Transparent" Foreground="White">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1F579;" FontSize="14" Margin="0,0,4,0"/>
                    <TextBlock Text="Hand" FontSize="12"/>
                </StackPanel>
            </Button>
            <Separator/>
            <Button Command="{Binding ShowDatabaseCommand}" ToolTip="Database" Margin="2,0"
                    Style="{StaticResource BaseButtonStyle}" Background="Transparent" Foreground="White">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1F5C4;" FontSize="14" Margin="0,0,4,0"/>
                    <TextBlock Text="Database" FontSize="12"/>
                </StackPanel>
            </Button>
            <Separator/>
            <Button Command="{Binding ShowToolManagementCommand}" ToolTip="Tool Management" Margin="2,0"
                    Style="{StaticResource BaseButtonStyle}" Background="Transparent" Foreground="White">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1F527;" FontSize="14" Margin="0,0,4,0"/>
                    <TextBlock Text="Tools" FontSize="12"/>
                </StackPanel>
            </Button>
            <Separator/>
            <Button Command="{Binding ShowIOMonitorCommand}" ToolTip="I/O Monitor" Margin="2,0"
                    Style="{StaticResource BaseButtonStyle}" Background="Transparent" Foreground="White">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x26A1;" FontSize="14" Margin="0,0,4,0"/>
                    <TextBlock Text="I/O" FontSize="12"/>
                </StackPanel>
            </Button>
            <Separator/>
            <Button Command="{Binding ShowProgramEditorCommand}" ToolTip="Program Editor" Margin="2,0"
                    Style="{StaticResource BaseButtonStyle}" Background="Transparent" Foreground="White">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1F4DD;" FontSize="14" Margin="0,0,4,0"/>
                    <TextBlock Text="Programs" FontSize="12"/>
                </StackPanel>
            </Button>
            <Separator/>
            <Button Command="{Binding ShowSettingsCommand}" ToolTip="Settings" Margin="2,0"
                    Style="{StaticResource BaseButtonStyle}" Background="Transparent" Foreground="White">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x2699;" FontSize="14" Margin="0,0,4,0"/>
                    <TextBlock Text="Settings" FontSize="12"/>
                </StackPanel>
            </Button>
            <Separator/>
            <Button Command="{Binding ShowAlarmsCommand}" ToolTip="Alarms" Margin="2,0"
                    Style="{StaticResource BaseButtonStyle}" Background="Transparent" Foreground="White">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1F514;" FontSize="14" Margin="0,0,4,0"/>
                    <TextBlock Text="Alarms" FontSize="12"/>
                </StackPanel>
            </Button>
            <!-- Spacer pushes status to right -->
            <TextBlock HorizontalAlignment="Right" Margin="40,0,0,0"/>
            <!-- Controller Status -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                <Ellipse Width="14" Height="14" Margin="0,0,6,0"
                         Fill="{Binding IsConnected, Converter={StaticResource BoolToConnectionColor}}"/>
                <TextBlock Text="{Binding ConnectionStatusText}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>
        </ToolBar>

        <!-- STATUS BAR -->
        <StatusBar DockPanel.Dock="Bottom" Background="{StaticResource PrimaryDarkBrush}" Height="24">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusBarMessage}" Foreground="White" FontSize="11"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Margin="0,0,4,0"
                             Fill="{Binding IsConnected, Converter={StaticResource BoolToConnectionColor}}"/>
                    <TextBlock Text="{Binding ConnectionStatusText}" Foreground="White" FontSize="11"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- MAIN CONTENT -->
        <ContentControl Content="{Binding CurrentView}" Margin="8"/>
    </DockPanel>
</Window>
